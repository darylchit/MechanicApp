# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Microsoft Azure Build Output
csx/
*.build.csdef

# Windows Store app package directories and files
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.appxupload

# SQL Server files
*.mdf
*.ldf
*.ndf

# Database files
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.rsuser
*- [Bb]ackup.rdl
*- [Bb]ackup ([0-9]).rdl
*- [Bb]ackup ([0-9][0-9]).rdl

# Node.js (if you use any frontend tooling)
node_modules/
npm-debug.log
yarn-error.log

# Sensitive configuration files (IMPORTANT!)
appsettings.Development.json
appsettings.Production.json
**/appsettings.*.json
!**/appsettings.json

# Migration files (optional - some teams commit these)
# **/Migrations/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Backup folder
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# Publish profiles
*.pubxml
*.publishproj

# Azure Stream Analytics local run output
ASALocalRun/

# MSTest test Results
[Tt]est[Rr]esult*/
